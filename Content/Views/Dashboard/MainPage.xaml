<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Dashboard.MainPage"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:progressBar="clr-namespace:MPowerKit.ProgressRing;assembly=MPowerKit.ProgressRing"
             xmlns:tabcell="clr-namespace:wwrc_maui.Content.Views.Dashboard"
             xmlns:vm="clr-namespace:wwrc_maui.Content.Viewmodels.Dashboard"
             NavigationPage.HasNavigationBar="False">

    <AbsoluteLayout HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1" RowDefinitions="Auto,*,Auto" ColumnDefinitions="*"
              RowSpacing="0" x:DataType="vm:MainPageVm">
            <!--nav bar-->
            <controls:CustomNavigationBar IconLeft="ic_filter" IconRight="ic_logout.png" BarImage="logo_db" 
                                          x:Name="navbar" TitleTextColor="#000000"/>
            <!--content-->
            <RefreshView HorizontalOptions="Fill" VerticalOptions="Fill" IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding RefreshCommand}" Grid.Row="1">
                <ScrollView HorizontalOptions="Fill" VerticalOptions="Fill">
                    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
                        <Label Text="{Binding Version}" FontSize="12" HorizontalOptions="Center" Margin="20,0"/>
                        <!--app version-->
                        <BoxView HorizontalOptions="Fill" Margin="0,10,0,8" Style="{StaticResource BoxviewNavbar}"/>
                        <!--subsidiary-->
                        <Label Text="{Binding Subsidiary}" HorizontalOptions="Center" LineBreakMode="TailTruncation"
                               MaxLines="1" Style="{StaticResource AlertTitle}" Grid.Row="0" Grid.Column="0"
                               Grid.ColumnSpan="3" Padding="8,0,8,8" FontSize="12"
                               IsVisible="{Binding IsSubsidiaryVisible}"/>
                        <!--date & currency-->
                        <Grid HorizontalOptions="Fill" ColumnSpacing="10" Margin="20,0,15,0" RowDefinitions="Auto"
                              ColumnDefinitions="0.55*,0.45*,30" Padding="0,0,0,8">
                            <!--exchange data-->
                            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Grid.Row="0"
                                                 Spacing="0" Grid.Column="0">
                                <Label Style="{StaticResource AlertTitle}" FontSize="12" HorizontalOptions="Start"
                                       Text="Exchange Date" LineBreakMode="TailTruncation"/>
                                <Label Style="{StaticResource PopupPromptButton}" HorizontalOptions="Start"
                                       Text="{Binding ExchangeDate, StringFormat='\{0:dd MMMM, yyyy}'}"
                                       LineBreakMode="TailTruncation" HorizontalTextAlignment="Start"
                                       FontSize="12"/>
                            </VerticalStackLayout>
                            <!--currency-->
                            <HorizontalStackLayout HorizontalOptions="Fill" Spacing="8" Grid.Row="0" Grid.Column="1">
                                <Image Source="{Binding FlagIcon}" Aspect="AspectFit" HorizontalOptions="Start"
                                       VerticalOptions="Center" HeightRequest="30" />
                                <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Spacing="0" >
                                    <Label Style="{StaticResource AlertTitle}" FontSize="12" HorizontalOptions="Start"
                                           Text="Currency" LineBreakMode="WordWrap"/>
                                    <Label Style="{StaticResource PopupPromptButton}" HorizontalOptions="Start" FontSize="12"
                                           Text="{Binding UsdRate, StringFormat='\USD {0}'}" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                            <!--img : arrow-->
                            <Image Source="{AppThemeBinding Light=ic_more, Dark=ic_more_light}" VerticalOptions="Center" 
                                   HorizontalOptions="End" Aspect="AspectFit" HeightRequest="30" Grid.Column="2"/>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDateCurrency_Tapped" NumberOfTapsRequired="1"/>
                            </Grid.GestureRecognizers>
                        </Grid>
                        <BoxView HeightRequest="1" HorizontalOptions="Fill" Margin="15,0"/>
                        <!--graph & percentage-->
                        <Grid HorizontalOptions="Fill" ColumnSpacing="10" VerticalOptions="Start" Margin="15,20"
                              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" RowSpacing="5">
                            <!--#region sales : ytd-->
                            <progressBar:ProgressRing Progress="{Binding YtdProgress}" VerticalOptions="Center"
                                    HorizontalOptions="Center" WidthRequest="100" HeightRequest="100" Smooth="True"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Black}}"
                                    Color="{StaticResource Secondary}" Thickness="5"/>
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                                <Label Text="{Binding CenterPercentYtd}" Style="{StaticResource PopupPromptButton}"/>
                                <Label Text=" %" Style="{StaticResource PopupPromptButton}"/>
                            </HorizontalStackLayout>
                            
                            <VerticalStackLayout HorizontalOptions="Fill" Grid.Row="1">
                                <Label Text="YTD Sales" HorizontalOptions="Center" Style="{StaticResource AlertTitle}"/>
                                <Label Text="{Binding YtdSales}" HorizontalOptions="Center" Style="{StaticResource PopupPromptButton}"
                                       TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Secondary}}"/>
                            </VerticalStackLayout>
                            <Border HorizontalOptions="Center" StrokeShape="RoundRectangle 10" Grid.Row="2" Padding="10,5"
                                    Style="{StaticResource BorderSecondary}">
                                <HorizontalStackLayout HorizontalOptions="Fill" Spacing="5">
                                    <Label Text="YTD GP" HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Primary}}"/>
                                    <Label Text="{Binding YtdDetails}" HorizontalOptions="Center" MaxLines="1"
                                           TextColor="{AppThemeBinding Light={StaticResource SecondaryDarkText}, Dark={StaticResource Secondary}}"
                                           LineBreakMode="TailTruncation"/>
                                </HorizontalStackLayout>
                            </Border>
                            <!--#endregion-->
                            <!--#region sales : mtd-->
                            <progressBar:ProgressRing Progress="{Binding MtdProgress}" VerticalOptions="Center"
                                    HorizontalOptions="Center" WidthRequest="100" HeightRequest="100" Smooth="True"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Black}}"
                                    Color="{StaticResource Primary}" Thickness="5" Grid.Column="1"/>
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Grid.Column="1">
                                <Label Text="{Binding CenterPercentMtd}" Style="{StaticResource PopupPromptButton}"/>
                                <Label Text=" %" Style="{StaticResource PopupPromptButton}"/>
                            </HorizontalStackLayout>
                            <VerticalStackLayout HorizontalOptions="Fill" Grid.Column="1" Grid.Row="1">
                                <Label Text="MTD Sales" HorizontalOptions="Center" Style="{StaticResource AlertTitle}"/>
                                <Label Text="{Binding MtdSales}" HorizontalOptions="Center" Style="{StaticResource PopupPromptButton}"
                                       TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource Primary}}"/>
                            </VerticalStackLayout>
                            <Border HorizontalOptions="Center" StrokeShape="RoundRectangle 10" Grid.Column="1" Grid.Row="2"
                                    Style="{StaticResource BorderSecondary}" Padding="10,5">
                                <HorizontalStackLayout HorizontalOptions="Fill" Spacing="5">
                                    <Label Text="MTD GP" HorizontalOptions="Center"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource Primary}}"/>
                                    <Label Text="{Binding MtdDetails}" HorizontalOptions="Center" MaxLines="1"
                                           TextColor="{AppThemeBinding Light={StaticResource PrimaryDark}, Dark={StaticResource Primary}}"
                                           LineBreakMode="TailTruncation"/>
                                </HorizontalStackLayout>
                            </Border>
                            <!--#endregion-->
                        </Grid>
                        <!--carousel menus-->
                        <CarouselView x:Name="carouselView" HorizontalOptions="Fill" VerticalOptions="Center"
                                      HorizontalScrollBarVisibility="Never" Margin="20,10" IndicatorView="indicatorView"
                                      ItemsSource="{Binding CarouselItems}" ItemTemplate="{Binding TemplateSelector}"/>
                        <!--carousel indicator-->
                        <IndicatorView x:Name="indicatorView" HorizontalOptions="Center" VerticalOptions="Center"
                                IndicatorColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray500}}" 
                                SelectedIndicatorColor="{StaticResource Primary}" IndicatorsShape="Circle"
                                Margin="20,10" IndicatorSize="15"/>
                    </VerticalStackLayout>
                </ScrollView>
            </RefreshView>
            <!--bottom tab bar-->
            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="End" Spacing="0" Grid.Row="2">
                <BoxView HeightRequest="1" HorizontalOptions="Fill" Margin="0,5,0,0"/>
                <Grid HorizontalOptions="Fill" RowDefinitions="Auto" ColumnDefinitions="*,*,*,*,*"
                      ColumnSpacing="0" Margin="0,10,0,15">
                    <tabcell:TabCell TabId="1" ImgDefault="menu_b_home_off" ImgSelected="menu_b_home_on"
                                     IsSelected="True" SetHeight="40" Title="Home" Grid.Column="0"/>
                    <tabcell:TabCell TabId="2" ImgDefault="menu_b_staff_off" ImgSelected="menu_b_staff_on"
                                     IsSelected="False" SetHeight="40" Title="Staff" Grid.Column="1"/>
                    <tabcell:TabCell TabId="3" ImgDefault="menu_b_sales_off" ImgSelected="menu_b_sales_on"
                                     IsSelected="False" SetHeight="40" Title="Sales" Grid.Column="2"/>
                    <tabcell:TabCell TabId="4" ImgDefault="menu_b_media_off" ImgSelected="menu_b_media_on"
                                     IsSelected="False" SetHeight="40" Title="Media" Grid.Column="3"/>
                    <tabcell:TabCell TabId="5" ImgDefault="menu_b_profile_off" ImgSelected="menu_b_profile_on"
                                     IsSelected="False" SetHeight="40" Title="Profile" Grid.Column="4"/>
                </Grid>
            </VerticalStackLayout>
        </Grid>
        <!--loading overlay-->
        <controls:CustomLoading AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"
                                x:Name="UiLoad" IsVisible="{Binding IsBusy}" IsAnimate="{Binding IsBusy}"/>
    </AbsoluteLayout>

</ContentPage>