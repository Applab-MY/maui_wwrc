<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Dashboard.FilterSalesPersonView"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:base="clr-namespace:wwrc_maui.Content.CustomControls.Base"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">
    
    <Grid HorizontalOptions="Fill" RowDefinitions="Auto,*" ColumnDefinitions="*"
          RowSpacing="10" VerticalOptions="Fill">
        <Grid.Resources>
            <ResourceDictionary>
                <helper:InverseBoolConverter x:Key="InverseBool"/>
            </ResourceDictionary>
        </Grid.Resources>
        <Border StrokeShape="RoundRectangle 20" HorizontalOptions="Fill" Padding="15,0">
            <base:BorderlessEntry x:Name="entry_" HorizontalOptions="Fill" VerticalOptions="Center"
                    Placeholder="search sales person..." TextChanged="OnEntry_TextChanged"/>
        </Border>
        <ListView HorizontalOptions="Fill" VerticalOptions="Start" HasUnevenRows="True" Grid.Row="1"
                  SeparatorVisibility="None" ItemsSource="{Binding MainSource}"
                  IsVisible="{Binding NoData, Converter={StaticResource InverseBool}}"
                  x:Name="listview" ItemTapped="listview_ItemTapped"
                  ItemAppearing="listview_ItemAppearing">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <VerticalStackLayout Spacing="0">
                            <Grid HorizontalOptions="Fill" ColumnSpacing="10" Padding="0,8"
                                  RowDefinitions="Auto" ColumnDefinitions="Auto,*,Auto">
                                <controls:CustomCircleImg ImgFromString="{Binding ProfileImage}" HorizontalOptions="Start"
                                                          SetSize="40" ImgAspect="AspectFit" Grid.Column="0"/>
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Fill"
                                                     Spacing="0" Grid.Column="1">
                                    <Label Text="{Binding Title}" FontAttributes="Bold" MaxLines="1"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding Position}" MaxLines="1" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                                <Image HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center"
                                       HorizontalOptions="End" Grid.Column="2">
                                    <Image.Triggers>
                                        <DataTrigger TargetType="Image" Binding="{Binding Checked}" Value="true">
                                            <Setter Property="Source" Value="ic_checked"/>
                                        </DataTrigger>
                                    </Image.Triggers>
                                </Image>
                            </Grid>
                            <BoxView HeightRequest="1" HorizontalOptions="Fill" Margin="10,0"/>
                        </VerticalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <controls:CustomNoData Grid.Row="1" Margin="0,15" HorizontalOptions="Center"
                               VerticalOptions="Center" IsVisible="{Binding NoData}"/>
    </Grid>
    
</ContentView>
