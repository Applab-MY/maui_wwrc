<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Media.Product.ProductDetailsCell"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">

    <ContentView.Resources>
        <ResourceDictionary>
            <helper:InverseBoolConverter x:Key="InverseBool"/>
            <helper:StringNullConverter x:Key="StringNull"/>
        </ResourceDictionary>
    </ContentView.Resources>
    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <Grid Margin="10" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*"
              ColumnSpacing="10" RowSpacing="5">
            <Image HeightRequest="35" Aspect="AspectFit" Grid.RowSpan="2" x:Name="img_file"
                   HorizontalOptions="Start" VerticalOptions="Center"/>
            <Label x:Name="lbl_title" LineBreakMode="WordWrap" FontSize="16"
                   Grid.Column="1" Style="{StaticResource AlertTitle}"/>
            <Label Grid.Column="1" Grid.Row="1" x:Name="lbl_size" HorizontalOptions="Center"
                   HorizontalTextAlignment="Center"/>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
        <Grid Margin="10" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*"
              ColumnSpacing="15" RowSpacing="10">
            <!--row 0-->
            <Label Text="File Type" Style="{StaticResource AlertTitle}" FontSize="16"/>
            <Label Grid.Column="1" x:Name="lbl_type" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                   VerticalOptions="Center" VerticalTextAlignment="Center"/>
            <!--row 1-->
            <Label Grid.Row="1" Text="Created On" Style="{StaticResource AlertTitle}" FontSize="16"/>
            <Label Grid.Row="1" Grid.Column="1" x:Name="lbl_createdt" LineBreakMode="WordWrap"
                   HorizontalOptions="Start" HorizontalTextAlignment="Start"
                   VerticalOptions="Center" VerticalTextAlignment="Center"/>
            <!--row 2-->
            <Label Grid.Row="2" Text="Created By" Style="{StaticResource AlertTitle}" FontSize="16"/>
            <Label Grid.Row="2" Grid.Column="1" x:Name="lbl_createby" LineBreakMode="WordWrap"
                   HorizontalOptions="Start" HorizontalTextAlignment="Start"
                   VerticalOptions="Center" VerticalTextAlignment="Center"/>
        </Grid>
    </VerticalStackLayout>

</ContentView>
