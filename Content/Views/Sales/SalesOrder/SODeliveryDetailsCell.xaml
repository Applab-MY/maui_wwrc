<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Sales.SalesOrder.SODeliveryDetailsCell"
          xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">
    <Grid HorizontalOptions="Fill" ColumnDefinitions="0.7*,0.3*" RowDefinitions="Auto"
          ColumnSpacing="10">
        <Label Text="{Binding ItemName}" HorizontalOptions="Fill" LineBreakMode="WordWrap"
               Margin="15,10,0,10" VerticalOptions="Center" HorizontalTextAlignment="Start"/>
        <Label Text="{Binding Quantity, StringFormat='{0:F2}'}" HorizontalOptions="End" MaxLines="1"
               Margin="0,10,15,10" VerticalOptions="Center" HorizontalTextAlignment="End" Grid.Column="1"
               Style="{StaticResource PopupPromptButton}" LineBreakMode="TailTruncation"/>
        <BoxView HeightRequest="1" HorizontalOptions="Fill" VerticalOptions="End" Grid.ColumnSpan="2"/>
    </Grid>
</ViewCell>
