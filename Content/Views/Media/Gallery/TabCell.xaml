<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Media.Gallery.TabCell">
    <Grid x:Name="grid_tab" HorizontalOptions="Fill" VerticalOptions="Fill"
          RowDefinitions="Auto" ColumnDefinitions="*">
        <Label x:Name="lbl_title" HorizontalOptions="Center" VerticalOptions="Center"
               Margin="15" HorizontalTextAlignment="Center"/>
        <BoxView HorizontalOptions="Fill" Style="{StaticResource BoxviewNavbar}"
                 x:Name="line" VerticalOptions="End" IsVisible="False"/>
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnCell_Tapped" NumberOfTapsRequired="1"/>
        </Grid.GestureRecognizers>
    </Grid>
</ContentView>
