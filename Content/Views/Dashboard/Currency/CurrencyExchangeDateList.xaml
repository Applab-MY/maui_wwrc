<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Dashboard.CurrencyExchangeDateList">
    <ListView HorizontalOptions="Fill" VerticalOptions="Center" HasUnevenRows="True"
              x:Name="listvw" SeparatorVisibility="None" ItemTapped="listvw_ItemTapped">
        <ListView.ItemTemplate>
            <DataTemplate>
                <ViewCell>
                    <Grid HorizontalOptions="Fill" RowDefinitions="Auto" ColumnDefinitions="*">
                        <Label Text="{Binding ., StringFormat='{0:dd MMM yyyy}'}" HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" Margin="15"/>
                        <BoxView HeightRequest="1" HorizontalOptions="Fill" VerticalOptions="End"/>
                    </Grid>
                </ViewCell>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentView>
