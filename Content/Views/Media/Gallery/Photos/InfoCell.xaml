<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Media.Gallery.Photos.InfoCell">

    <Grid HorizontalOptions="Fill" RowDefinitions="Auto,Auto,Auto,Auto,Auto" ColumnDefinitions="Auto,*"
          RowSpacing="10" ColumnSpacing="10" VerticalOptions="Fill">
        <!--row 1 : title-->
        <Label Text="Title" FontAttributes="Bold" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" LineBreakMode="TailTruncation" Grid.Row="0" Grid.Column="0"/>
        <Label x:Name="lbl_title" Text="-" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" VerticalTextAlignment="Start" LineBreakMode="WordWrap"
               Grid.Row="0" Grid.Column="1"/>
        <!--row 2 : date-->
        <Label Text="Date" FontAttributes="Bold" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" LineBreakMode="TailTruncation" Grid.Row="1" Grid.Column="0"/>
        <Label x:Name="lbl_date" Text="-" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" VerticalTextAlignment="Start" LineBreakMode="WordWrap"
               Grid.Row="1" Grid.Column="1"/>
        <!--row 3 : description-->
        <Label Text="Description" FontAttributes="Bold" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" LineBreakMode="TailTruncation" Grid.Row="2" Grid.Column="0"/>
        <Label x:Name="lbl_desc" Text="-" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" VerticalTextAlignment="Start" LineBreakMode="WordWrap"
               Grid.Row="2" Grid.Column="1"/>
        <!--row 4 : created on-->
        <Label Text="Created On" FontAttributes="Bold" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" LineBreakMode="TailTruncation" Grid.Row="3" Grid.Column="0"/>
        <Label x:Name="lbl_createOn" Text="-" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" VerticalTextAlignment="Start" LineBreakMode="WordWrap"
               Grid.Row="3" Grid.Column="1"/>
        <!--row 5 : created by-->
        <Label Text="Created By" FontAttributes="Bold" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" LineBreakMode="TailTruncation" Grid.Row="4" Grid.Column="0"/>
        <Label x:Name="lbl_createBy" Text="-" HorizontalOptions="Start" HorizontalTextAlignment="Start"
               VerticalOptions="Start" VerticalTextAlignment="Start" LineBreakMode="WordWrap"
               Grid.Row="4" Grid.Column="1"/>
    </Grid>
    
</ContentView>
