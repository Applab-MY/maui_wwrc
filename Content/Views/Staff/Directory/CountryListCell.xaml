<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Staff.Directory.CountryListCell"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:base="clr-namespace:wwrc_maui.Content.CustomControls.Base">

    <Grid HorizontalOptions="Fill" RowDefinitions="Auto,*" ColumnDefinitions="*"
          RowSpacing="10" VerticalOptions="Fill">
        <Border StrokeShape="RoundRectangle 20" HorizontalOptions="Fill" Padding="15,0">
            <base:BorderlessEntry x:Name="entry_" HorizontalOptions="Fill" VerticalOptions="Center"
                    Placeholder="search country..." TextChanged="OnEntry_TextChanged"/>
        </Border>
        <ListView HorizontalOptions="Fill" VerticalOptions="Start" HasUnevenRows="True" Grid.Row="1"
                  SeparatorVisibility="None" ItemsSource="{Binding Itemsource}"
                  x:Name="listview" ItemTapped="listview_ItemTapped">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <VerticalStackLayout Spacing="0">
                            <Grid HorizontalOptions="Fill" ColumnSpacing="10" Padding="0,8"
                                  RowDefinitions="Auto" ColumnDefinitions="Auto,*">
                                <controls:CustomCircleImg ImgFromString="{Binding CountryImage}" HorizontalOptions="Start"
                                                          SetSize="40" ImgAspect="AspectFill" Grid.Column="0"/>
                                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Fill"
                                                     Spacing="0" Grid.Column="1">
                                    <Label Text="{Binding CountryName}" FontAttributes="Bold" MaxLines="1"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding CountryCode}" MaxLines="1" LineBreakMode="TailTruncation"/>
                                </VerticalStackLayout>
                            </Grid>
                            <BoxView HeightRequest="1" HorizontalOptions="Fill" Margin="10,0"/>
                        </VerticalStackLayout>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>

</ContentView>
