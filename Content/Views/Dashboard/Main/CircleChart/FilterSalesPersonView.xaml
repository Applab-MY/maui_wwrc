<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Dashboard.Main.FilterSalesPersonView"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:base="clr-namespace:wwrc_maui.Content.CustomControls.Base"
             xmlns:cell="clr-namespace:wwrc_maui.Content.Views.Dashboard.Main.CircleChart"
             xmlns:vm="clr-namespace:wwrc_maui.Content.Viewmodels.Dashboard"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">

    <Grid HorizontalOptions="Fill" RowDefinitions="Auto,*" ColumnDefinitions="*"
          RowSpacing="10" VerticalOptions="Fill" x:DataType="vm:GraphDetailsVm">
        <Grid.Resources>
            <ResourceDictionary>
                <helper:InverseBoolConverter x:Key="InverseBool"/>
            </ResourceDictionary>
        </Grid.Resources>
        <Border StrokeShape="RoundRectangle 20" HorizontalOptions="Fill" Padding="15,0">
            <base:BorderlessEntry x:Name="entry_" HorizontalOptions="Fill" VerticalOptions="Center"
                    Placeholder="search sales person..." TextChanged="OnEntry_TextChanged"/>
        </Border>
        <ListView HorizontalOptions="Fill" VerticalOptions="Start" HasUnevenRows="True" Grid.Row="1"
                  SeparatorVisibility="None" ItemsSource="{Binding AllSalesPerson}"
                  IsVisible="{Binding NoSalesPerson, Converter={StaticResource InverseBool}}"
                  x:Name="listview" ItemTapped="listview_ItemTapped"
                  ItemAppearing="listview_ItemAppearing">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <cell:FilterSalesPersonCell/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <controls:CustomNoData Grid.Row="1" Margin="0,15" HorizontalOptions="Center"
                               VerticalOptions="Center" IsVisible="{Binding NoSalesPerson}"/>
    </Grid>

</ContentView>
