<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Sales.SalesOrder.SalesOrderDetailsCellDo"
          xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">
    <Grid HorizontalOptions="Fill" ColumnDefinitions="*,*,Auto" RowDefinitions="Auto"
          ColumnSpacing="10">
        <HorizontalStackLayout HorizontalOptions="Start" VerticalOptions="Center" Spacing="10">
            <Image Source="{Binding ImageDotSource}" HeightRequest="15" Aspect="AspectFit"
                   Margin="15,10,0,10" VerticalOptions="Center" HorizontalOptions="Start"/>
            <Label Text="{Binding DONO}" HorizontalOptions="Fill" MaxLines="1" LineBreakMode="TailTruncation"
                   Margin="0,10,0,10" VerticalOptions="Center" HorizontalTextAlignment="Start"/>
        </HorizontalStackLayout>
        <Label Text="{Binding DODate}" HorizontalOptions="End" MaxLines="1" LineBreakMode="TailTruncation"
               Margin="0,10" VerticalOptions="Center" HorizontalTextAlignment="End" Grid.Column="1"
               Style="{StaticResource PopupPromptButton}"/>
        <Image Source="{AppThemeBinding Light=ic_more, Dark=ic_more_light}" HeightRequest="20"
               Aspect="AspectFit" VerticalOptions="Center" Grid.Column="2" Margin="0,10,10,10"
               HorizontalOptions="End"/>
        <BoxView HeightRequest="1" HorizontalOptions="Fill" VerticalOptions="End" Grid.ColumnSpan="3"/>
    </Grid>
</ViewCell>
