<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Staff.Directory.OthersTabDetailsPage"
             xmlns:vm="clr-namespace:wwrc_maui.Content.Viewmodels.Staff"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:cell="clr-namespace:wwrc_maui.Content.Views.Staff.Directory"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helper:InverseBoolConverter x:Key="InverseBool"/>
            <helper:StringNullConverter x:Key="StringNull"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    <AbsoluteLayout HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1" RowDefinitions="Auto,*" ColumnDefinitions="*"
              RowSpacing="0" x:DataType="vm:StaffDetailsVm">
            <!--nav bar-->
            <controls:CustomNavigationBar IconLeft="ic_back" IconRight="ic_search" x:Name="navbar"/>
            <!--country picker-->
            <Grid HorizontalOptions="Center" RowDefinitions="Auto" ColumnDefinitions="Auto" Margin="20,5"
                  VerticalOptions="Center">
                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="5">
                    <Image Source="{Binding SelectedCountry.CountryImage}" HeightRequest="30" Aspect="AspectFit"
                               VerticalOptions="Center" HorizontalOptions="Start" Margin="0,0,5,0"/>
                    <Label Text="{Binding SelectedCountry.CountryName, Converter={StaticResource StringNull}}"
                               HorizontalOptions="Center" MaxLines="1" LineBreakMode="TailTruncation"
                               Style="{StaticResource PopupPromptButton}" VerticalOptions="Center"
                               VerticalTextAlignment="Center"/>
                    <Image Source="{AppThemeBinding Light=ic_dropdown, Dark=ic_dropdown_light}" HeightRequest="30"
                           Aspect="AspectFit" VerticalOptions="Center" HorizontalOptions="End"/>
                    <HorizontalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnPickCountry_Tapped" NumberOfTapsRequired="1"/>
                    </HorizontalStackLayout.GestureRecognizers>
                </HorizontalStackLayout>
            </Grid>
            <BoxView HorizontalOptions="Fill" Margin="0" Style="{StaticResource BoxviewNavbar}"
                     VerticalOptions="End"/>
            <!--row 1 : content-->
            <Grid HorizontalOptions="Fill" VerticalOptions="Fill" Grid.Row="1" ColumnDefinitions="*"
                  RowDefinitions="Auto,*,Auto" RowSpacing="5">
                <!--row 1 : search bar-->
                <controls:CustomEntry HorizontalOptions="Fill" Placeholder="search staff..."
                        VerticalOptions="Start" x:Name="entry_search" Margin="20,10" SetText="SearchTxt"
                        SetWidth="{Binding EntryWidth}" IsVisible="{Binding IsSearchVisible}"/>
                <!--row 2 : tab content-->
                <ListView HorizontalOptions="Fill" ItemsSource="{Binding StaffListMain}" HasUnevenRows="True"
                          IsPullToRefreshEnabled="True" IsRefreshing="{Binding IsRefreshing}" Grid.Row="1"
                          RefreshCommand="{Binding RefreshCommand}" IsGroupingEnabled="False"
                          VerticalOptions="Fill" ItemTapped="ListView_ItemTapped" Margin="15,0">
                    <!--<ListView.GroupHeaderTemplate>
                        <DataTemplate>
                            <cell:OfficeTabCellGroup/>
                        </DataTemplate>
                    </ListView.GroupHeaderTemplate>-->
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <cell:OfficeTabCell/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!--no data-->
                <controls:CustomNoData Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center"
                                       IsVisible="{Binding NoData}"/>
                <!--row 3 : btn select-->
                <Grid HorizontalOptions="Fill" ColumnDefinitions="*" RowDefinitions="Auto" Grid.Row="2"
                      VerticalOptions="End" Margin="15,0,15,10">
                    <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="End" Spacing="10">
                        <Button Text="Select" BackgroundColor="{StaticResource Key=Primary}" HorizontalOptions="Center"
                                x:Name="btn_select" VerticalOptions="End" Clicked="OnSelect_Clicked" Padding="15,0"
                                IsVisible="{Binding IsSelectable}" />
                        <Button Text="{Binding SelectableCount, StringFormat='\Clear ({0})'}" HorizontalOptions="Center"
                                Style="{StaticResource Key=BtnTertiary}" x:Name="btn_clear" VerticalOptions="End"
                                Clicked="OnClear_Clicked" Padding="15,0" IsVisible="{Binding ShowClearSelectable}" />
                    </HorizontalStackLayout>
                </Grid>
            </Grid>
        </Grid>
        <!--loading overlay-->
        <controls:CustomLoading AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"
                        x:Name="UiLoad" IsVisible="{Binding IsBusy}" IsAnimate="{Binding IsBusy}"/>
    </AbsoluteLayout>

</ContentPage>