<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Sales.SalesOrder.SalesOrderDetailsCellSo"
          xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">

    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <VerticalStackLayout.Resources>
            <ResourceDictionary>
                <helper:InverseBoolConverter x:Key="InverseBool"/>
                <helper:StringNullConverter x:Key="StringNull"/>
            </ResourceDictionary>
        </VerticalStackLayout.Resources>
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" ColumnSpacing="8" RowSpacing="0"
              RowDefinitions="Auto" ColumnDefinitions="0.35*,0.25*,0.2*,0.2*" Margin="15">
            <!--title-->
            <Label Text="{Binding ItemName, Converter={StaticResource StringNull}}" HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start" VerticalOptions="Start" LineBreakMode="WordWrap"
                   FontSize="12"/>
            <!--unit price-->
            <Label Text="{Binding UnitPrice, Converter={StaticResource StringNull}}" Grid.Column="1"
                   HorizontalOptions="Start" MaxLines="1" LineBreakMode="CharacterWrap"
                   VerticalOptions="Start" HorizontalTextAlignment="Start"/>
            <!--qty-->
            <Label Text="{Binding Quantity, Converter={StaticResource StringNull}}" Grid.Column="2"
                   HorizontalOptions="Center" MaxLines="1" LineBreakMode="CharacterWrap"
                   VerticalOptions="Start" HorizontalTextAlignment="Center"/>
            <!--open qty-->
            <Label Text="{Binding OpenQTY, Converter={StaticResource StringNull}}" Grid.Column="3"
                   HorizontalOptions="End" MaxLines="1" LineBreakMode="CharacterWrap"
                   VerticalOptions="Start" HorizontalTextAlignment="End"/>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
    </VerticalStackLayout>

</ViewCell>
