<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.CustomControls.CustomNoData">
    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
        <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
            <Image Source="{AppThemeBinding Light=ic_elipse_info, Dark=ic_elipse_info_2}"
                   HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center"/>
            <Label Text="No data available..." VerticalOptions="Center"/>
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentView>
