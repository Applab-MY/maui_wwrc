<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Sales.CustomerAging.CustomerAgingCell"
          xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">
    
    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <VerticalStackLayout.Resources>
            <ResourceDictionary>
                <helper:InverseBoolConverter x:Key="InverseBool"/>
                <helper:StringNullConverter x:Key="StringNull"/>
            </ResourceDictionary>
        </VerticalStackLayout.Resources>
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" ColumnSpacing="10" RowSpacing="0"
              RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*" Margin="15">
            <!--#region row 1: title-->
            <Label Text="{Binding CardName, Converter={StaticResource StringNull}}" HorizontalOptions="Fill"
                   HorizontalTextAlignment="Start" VerticalOptions="Start" Style="{StaticResource PopupPromptButton}"
                   LineBreakMode="WordWrap" FontSize="14" Margin="0,0,0,8" Grid.ColumnSpan="2">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                        <Setter Property="TextColor" Value="Red"/>
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <!--#endregion-->
            <!--#region row 2-->
            <Label Text="{Binding CardCode, Converter={StaticResource StringNull}}" Grid.Row="1" Grid.Column="0"
                   HorizontalOptions="Start" MaxLines="1" LineBreakMode="TailTruncation" Margin="8,0"
                   VerticalOptions="Center">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                        <Setter Property="TextColor" Value="Red"/>
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <Label Text="{Binding TotalOverdue, StringFormat='{0:N2}'}" Grid.Row="1" Grid.Column="1"
                   FontAttributes="Bold" HorizontalOptions="End" MaxLines="1" LineBreakMode="TailTruncation"
                   HorizontalTextAlignment="End" VerticalOptions="Center" Style="{StaticResource PopupPromptButton}">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                        <Setter Property="TextColor" Value="Red"/>
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <!--#endregion-->
            <!--#region row 3-->
            <HorizontalStackLayout HorizontalOptions="Fill" Spacing="5" Grid.Row="2" Grid.Column="0"
                                   VerticalOptions="Center" Margin="8,0">
                <Label Text="{Binding startDate, Converter={StaticResource StringNull}}" 
                       VerticalOptions="Center" VerticalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                            <Setter Property="TextColor" Value="Red"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="-" VerticalOptions="Center" VerticalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                            <Setter Property="TextColor" Value="Red"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="{Binding endDate, Converter={StaticResource StringNull}}"
                       VerticalOptions="Center" VerticalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                            <Setter Property="TextColor" Value="Red"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </HorizontalStackLayout>
            <Label Text="{Binding status, Converter={StaticResource StringNull}}" Grid.Row="2" Grid.Column="1"
                   HorizontalOptions="End" HorizontalTextAlignment="End">
                <Label.Triggers>
                    <DataTrigger TargetType="Label" Binding="{Binding ALERT}" Value="ic_status_red">
                        <Setter Property="TextColor" Value="Red"/>
                    </DataTrigger>
                </Label.Triggers>
            </Label>
            <!--#endregion-->
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
    </VerticalStackLayout>
    
</ViewCell>
