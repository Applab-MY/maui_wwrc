<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Profile.ChangePassword.ChangePasswordMainPage"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:vm="clr-namespace:wwrc_maui.Content.Viewmodels.Profile"
             NavigationPage.HasNavigationBar="False">

    <AbsoluteLayout HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1" RowDefinitions="Auto,*" ColumnDefinitions="*"
              RowSpacing="0" x:DataType="vm:ChangePasswordVm">
            <!--nav bar-->
            <controls:CustomNavigationBar IconLeft="ic_back" x:Name="navbar" Title="Change Password"/>
            <BoxView HorizontalOptions="Fill" Margin="0" Style="{StaticResource BoxviewNavbar}"
                     VerticalOptions="End"/>
            <!--content-->
            <Grid HorizontalOptions="Fill" VerticalOptions="Fill" Grid.Row="1" ColumnDefinitions="*"
                  RowDefinitions="*">
                <!--row 1 : content-->
                <ScrollView HorizontalOptions="Fill" VerticalOptions="Fill">
                    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Start" Spacing="0">
                        <Label Text="Requires minimum 8 characters, 1 lower letter, 1 upper letter, 1 symbol &amp; 1 number"
                               HorizontalOptions="Center" Style="{StaticResource AlertTitle}" HorizontalTextAlignment="Center"
                               VerticalOptions="Center" FontSize="14" Margin="20,20"/>
                        <controls:CustomEntry SetText="CurrentPwd" Ispassword="True" SetWidth="{Binding EntryWidth}"
                                              VerticalOptions="Center" Margin="20,20,20,0" EntryIcon="ic_password"/>
                        <controls:CustomEntry SetText="NewPwd" Ispassword="True" SetWidth="{Binding EntryWidth}"
                                              VerticalOptions="Center" Margin="20,10,20,0" EntryIcon="ic_password"/>
                        <controls:CustomEntry SetText="ConfirmPwd" Ispassword="True" SetWidth="{Binding EntryWidth}"
                                              VerticalOptions="Center" Margin="20,10,20,0" EntryIcon="ic_password"/>
                        <Button Text="Submit" Command="{Binding SubmitCommand}" VerticalOptions="Center" Margin="20,30,20,0"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Grid>
        </Grid>
        <!--loading overlay-->
        <controls:CustomLoading AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"
                                x:Name="UiLoad" IsVisible="{Binding IsBusy}" IsAnimate="{Binding IsBusy}"/>
    </AbsoluteLayout>
    
</ContentPage>