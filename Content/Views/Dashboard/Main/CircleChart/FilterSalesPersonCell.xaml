<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Dashboard.Main.CircleChart.FilterSalesPersonCell"
          xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls">

    <VerticalStackLayout Spacing="0">
        <Grid HorizontalOptions="Fill" ColumnSpacing="10" Padding="0,8"
              RowDefinitions="Auto" ColumnDefinitions="Auto,*,Auto">
            <controls:CustomCircleImg ImgFromString="{Binding ProfileImage}" HorizontalOptions="Start"
                                      SetSize="40" ImgAspect="AspectFit" Grid.Column="0"/>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Fill" Spacing="0" Grid.Column="1">
                <Label Text="{Binding Title}" FontAttributes="Bold" MaxLines="1" LineBreakMode="TailTruncation"/>
                <Label Text="{Binding Position}" MaxLines="1" LineBreakMode="TailTruncation"/>
            </VerticalStackLayout>
            <Image HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center" Source="ic_checked"
                   HorizontalOptions="End" Grid.Column="2" IsVisible="{Binding Checked}"/>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill" Margin="10,0"/>
    </VerticalStackLayout>

</ViewCell>
