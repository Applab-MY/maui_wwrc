<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Media.News.NewsListCell">
    
    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" ColumnSpacing="10" RowSpacing="0"
              ColumnDefinitions="*,Auto" Margin="15,10,15,0">
            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Start" Spacing="0">
                <Label Text="{Binding Title}" LineBreakMode="WordWrap" HorizontalTextAlignment="Start">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="false">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="true">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontAttributes" Value="None"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <Label Text="{Binding Date}" LineBreakMode="TailTruncation" HorizontalTextAlignment="Start">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="false">
                            <Setter Property="FontSize" Value="16"/>
                            <Setter Property="FontAttributes" Value="Bold"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="true">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontAttributes" Value="None"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </VerticalStackLayout>
            <Image Source="{Binding DefaultImg}" HeightRequest="70" HorizontalOptions="End"
                   Aspect="AspectFit" Grid.Column="1" VerticalOptions="Start"/>
        </Grid>
        <Label Text="{Binding Description}" Style="{StaticResource AlertTitle}" FontSize="12"
               HorizontalTextAlignment="Start" MaxLines="5" LineBreakMode="TailTruncation"
               Margin="15,10,15,20" HorizontalOptions="Start"/>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
    </VerticalStackLayout>
    
</ViewCell>
