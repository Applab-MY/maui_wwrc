<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Media.EmpHandbook.HandbookDetailsCell"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">

    <ContentView.Resources>
        <ResourceDictionary>
            <helper:InverseBoolConverter x:Key="InverseBool"/>
            <helper:StringNullConverter x:Key="StringNull"/>
        </ResourceDictionary>
    </ContentView.Resources>
    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <Grid Margin="10" RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,*"
              ColumnSpacing="10" RowSpacing="10">
            <Image HeightRequest="30" Aspect="AspectFit" Grid.RowSpan="2" Source="ic_pdf"
                   HorizontalOptions="Start" VerticalOptions="Center"/>
            <Label Text="{Binding Title, Converter={StaticResource StringNull}}" LineBreakMode="WordWrap"
                   Grid.Column="1" Style="{StaticResource AlertTitle}" FontSize="14"/>
            <Label Grid.Column="1" Grid.Row="1" Text="{Binding Filesize, Converter={StaticResource StringNull}}"/>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
        <Grid Margin="10" RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="Auto,*"
              ColumnSpacing="10" RowSpacing="10">
            <!--row 0-->
            <Label Text="File Type" Style="{StaticResource AlertTitle}" FontSize="14"/>
            <Label Grid.Column="1" Text="{Binding FileType, Converter={StaticResource StringNull}}" />
            <!--row 1-->
            <Label Grid.Row="1" Text="Created On" Style="{StaticResource AlertTitle}" FontSize="14"/>
            <Label Grid.Row="1" Grid.Column="1" Text="{Binding CreateDate, Converter={StaticResource StringNull}}"
                   LineBreakMode="WordWrap"/>
            <!--row 2-->
            <Label Grid.Row="2" Text="Created By" Style="{StaticResource AlertTitle}" FontSize="14"/>
            <Label Grid.Row="2" Grid.Column="1" Text="{Binding CreateByName, Converter={StaticResource StringNull}}"
                   LineBreakMode="WordWrap"/>
        </Grid>
    </VerticalStackLayout>

</ContentView>
