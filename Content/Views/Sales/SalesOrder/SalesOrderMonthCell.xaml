<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Sales.SalesOrder.SalesOrderMonthCell"
          xmlns:helper="clr-namespace:wwrc_maui.Content.Helper">
    <VerticalStackLayout HorizontalOptions="Fill" Spacing="0">
        <Grid HorizontalOptions="Fill" ColumnSpacing="10" RowDefinitions="Auto,Auto" Margin="15,5,15,15"
              ColumnDefinitions="Auto,*,Auto">
            <Grid.Resources>
                <ResourceDictionary>
                    <helper:InverseBoolConverter x:Key="InverseBool"/>
                    <helper:StringNullConverter x:Key="StringNull"/>
                </ResourceDictionary>
            </Grid.Resources>
            <!--icon-->
            <Image Source="ic_status_red" HeightRequest="20" Aspect="AspectFit" HorizontalOptions="Start"
                   VerticalOptions="Center" Grid.RowSpan="2">
                <Image.Triggers>
                    <DataTrigger TargetType="Image" Binding="{Binding DocStatus}" Value="O">
                        <Setter Property="Source" Value="ic_status_green"/>
                    </DataTrigger>
                </Image.Triggers>
            </Image>
            <!--details-->
            <VerticalStackLayout HorizontalOptions="Fill" Spacing="0" Margin="0,10" Grid.Column="1"
                                 VerticalOptions="Center" Grid.ColumnSpan="2">
                <Label Text="{Binding SONO}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                       MaxLines="1" LineBreakMode="TailTruncation" Style="{StaticResource PopupPromptButton}"/>
                <Label Text="{Binding CardName}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                       MaxLines="1" LineBreakMode="TailTruncation"/>
                <Label Text="{Binding CardCode}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                       MaxLines="1" LineBreakMode="TailTruncation"/>
            </VerticalStackLayout>
            <!--datetime-->
            <VerticalStackLayout HorizontalOptions="Fill" Spacing="0" Grid.Row="1" Grid.Column="1"
                                 VerticalOptions="End">
                <Label Text="SO Date :" HorizontalOptions="Start" VerticalOptions="End"
                       VerticalTextAlignment="End"/>
                <Label Text="{Binding PostingDate}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                       MaxLines="1" LineBreakMode="TailTruncation" VerticalTextAlignment="End"
                       VerticalOptions="End" FontSize="12"/>
            </VerticalStackLayout>
            <BoxView WidthRequest="1" VerticalOptions="Fill" Grid.Row="1" Grid.Column="2" HorizontalOptions="Start"/>
            <!--delivery date-->
            <VerticalStackLayout HorizontalOptions="Fill" Spacing="0" VerticalOptions="End"
                                 Grid.Row="1" Grid.Column="2" Padding="15,0,0,0">
                <Label Text="Delivery Date" HorizontalOptions="End" HorizontalTextAlignment="End"
                       MaxLines="1" LineBreakMode="TailTruncation" VerticalTextAlignment="End"
                       VerticalOptions="End"/>
                <Label Text="{Binding DeliveryDate}" HorizontalOptions="End" HorizontalTextAlignment="End"
                       MaxLines="1" LineBreakMode="TailTruncation" VerticalTextAlignment="End"
                       VerticalOptions="End" FontSize="12"/>
            </VerticalStackLayout>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill" VerticalOptions="End" Grid.Row="1" Grid.Column="2"/>
    </VerticalStackLayout>
</ViewCell>
