<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Staff.CustomerVisit.CustomerVisitMainPage"
             xmlns:base="clr-namespace:wwrc_maui.Content.CustomControls.Base"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:cell="clr-namespace:wwrc_maui.Content.Views.Staff.CustomerVisit"
             xmlns:vm="clr-namespace:wwrc_maui.Content.Viewmodels.Staff"
             xmlns:helper="clr-namespace:wwrc_maui.Content.Helper"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <helper:InverseBoolConverter x:Key="InverseBool"/>
            <helper:StringNullConverter x:Key="StringNull"/>
        </ResourceDictionary>
    </ContentPage.Resources>
    <AbsoluteLayout HorizontalOptions="Fill" VerticalOptions="Fill" BackgroundColor="Transparent">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" AbsoluteLayout.LayoutFlags="All"
              AbsoluteLayout.LayoutBounds="0,0,1,1" RowDefinitions="Auto,*" ColumnDefinitions="*"
              RowSpacing="0" x:DataType="vm:CustomerVisitVm">
            <!--nav bar-->
            <controls:CustomNavigationBar IconLeft="ic_back" x:Name="navbar" Title="Customer Visit"
                                          IconRight="ic_add"/>
            <BoxView HorizontalOptions="Fill" Margin="0" Style="{StaticResource BoxviewNavbar}"
                     VerticalOptions="End"/>
            <!--content-->
            <Grid HorizontalOptions="Fill" VerticalOptions="Fill" Grid.Row="1" ColumnDefinitions="*"
                  RowDefinitions="Auto,*">
                <!--filter list-->
                <Grid HorizontalOptions="Fill" ColumnSpacing="15" Margin="20,10,15,10" RowDefinitions="Auto"
                      ColumnDefinitions="0.5*,0.5*" Padding="0">
                    <!--sales person-->
                    <Grid HorizontalOptions="Fill" ColumnSpacing="15" Grid.Row="0" Grid.Column="0"
                          ColumnDefinitions="*,Auto">
                        <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Spacing="0">
                            <Label Style="{StaticResource AlertTitle}" FontSize="14" HorizontalOptions="Start"
                                   Text="Sales Person" LineBreakMode="TailTruncation"/>
                            <Label Style="{StaticResource PopupPromptButton}" HorizontalOptions="Start"
                                   Text="{Binding SalesPerson, Converter={StaticResource StringNull}}"
                                   LineBreakMode="TailTruncation" HorizontalTextAlignment="Start" FontSize="14"/>
                        </VerticalStackLayout>
                        <!--img : arrow-->
                        <Image Source="{AppThemeBinding Light=ic_dropdown, Dark=ic_dropdown_light}" VerticalOptions="Center" 
                               HorizontalOptions="End" Aspect="AspectFit" HeightRequest="30" Grid.Column="1"/>
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSalesPerson_Tapped" NumberOfTapsRequired="1"/>
                        </Grid.GestureRecognizers>
                    </Grid>
                    <!--from date-->
                    <Grid HorizontalOptions="Fill" ColumnSpacing="5" Grid.Row="0" Grid.Column="1" ColumnDefinitions="*,Auto"
                          BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource OffBlack}}">
                        <!--title, value-->
                        <VerticalStackLayout HorizontalOptions="Fill" Spacing="0">
                            <Label Style="{StaticResource AlertTitle}" FontSize="14" HorizontalOptions="Start"
                                   Text="From Date" LineBreakMode="WordWrap"/>
                            <!--<Label Style="{StaticResource PopupPromptButton}" HorizontalOptions="Start"
                                   Text="{Binding SelectedDate, StringFormat='\{0:dd MMM yyyy}'}"
                                   LineBreakMode="TailTruncation" HorizontalTextAlignment="Start" FontSize="14"/>-->
                        </VerticalStackLayout>
                        <base:BorderlessDatePicker x:Name="dt_from" HorizontalOptions="Fill" Format="dd MMM yyyy"
                                    Date="{Binding SelectedDate}" Style="{StaticResource DatepickerPrimary}"
                                    DateSelected="OnDateFrom_DateSelected" Margin="0,3,0,-10"/>
                        <!--img : arrow-->
                        <Image Source="{AppThemeBinding Light=ic_dropdown, Dark=ic_dropdown_light}" VerticalOptions="Center" 
                               HorizontalOptions="End" Aspect="AspectFit" HeightRequest="30" Grid.Column="1"/>
                        <!--<Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFromDate_Tapped" NumberOfTapsRequired="1"/>
                        </Grid.GestureRecognizers>-->
                    </Grid>
                </Grid>
                <BoxView HeightRequest="1" HorizontalOptions="Fill" VerticalOptions="End"/>
                <!--row 2 : listview-->
                <ListView HorizontalOptions="Fill" ItemsSource="{Binding MainVisitList}" SeparatorVisibility="None"
                          HasUnevenRows="True" VerticalOptions="Fill" ItemTapped="ListView_ItemTapped" Grid.Row="1"
                          Margin="0,15,0,5" IsVisible="{Binding NoData, Converter={StaticResource InverseBool}}"
                          IsPullToRefreshEnabled="true" RefreshCommand="{Binding RefreshCommand}"
                          IsRefreshing="{Binding IsRefreshing}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <cell:CustomerVisitMainCell/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <!--no data-->
                <controls:CustomNoData Grid.Row="1" HorizontalOptions="Center" VerticalOptions="Center"
                                       IsVisible="{Binding NoData}"/>
            </Grid>
        </Grid>
        <!--loading overlay-->
        <controls:CustomLoading AbsoluteLayout.LayoutFlags="All" AbsoluteLayout.LayoutBounds="0,0,1,1"
                    x:Name="UiLoad" IsVisible="{Binding IsBusy}" IsAnimate="{Binding IsBusy}"/>
    </AbsoluteLayout>

</ContentPage>