<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="wwrc_maui.Content.Views.Media.MediaOptionPage"
             xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
             xmlns:cell="clr-namespace:wwrc_maui.Content.Views.Media"
             NavigationPage.HasNavigationBar="False">
    
    <Grid HorizontalOptions="Fill" VerticalOptions="Fill" RowDefinitions="Auto,*" ColumnDefinitions="*">
        <BoxView HorizontalOptions="Fill" Margin="0,0,0,15" Style="{StaticResource BoxviewNavbar}"
                 VerticalOptions="Start" Grid.Row="0"/>
        <ListView HorizontalOptions="Fill" VerticalOptions="Start" HasUnevenRows="True" Grid.Row="1"
                  SeparatorVisibility="None" ItemTapped="ListView_ItemTapped" x:Name="listview">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <cell:MediaOptionCell/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>

</ContentView>