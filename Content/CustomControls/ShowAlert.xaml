<?xml version="1.0" encoding="utf-8" ?>
<pages:PopupPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                 x:Class="wwrc_maui.Content.CustomControls.ShowAlert"
                 xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
                 xmlns:helper="clr-namespace:wwrc_maui.Content.Helper"
                 xmlns:pages="clr-namespace:RGPopup.Maui.Pages;assembly=RGPopup.Maui"
                 xmlns:animations="clr-namespace:RGPopup.Maui.Animations;assembly=RGPopup.Maui"
                 xmlns:controls="clr-namespace:wwrc_maui.Content.CustomControls"
                 xmlns:base="clr-namespace:wwrc_maui.Content.CustomControls.Base"
                 CloseWhenBackgroundIsClicked="False">
    <!--<pages:PopupPage.Animation>
    <animations:ScaleAnimation PositionIn="Center" PositionOut="Center" ScaleIn="1.2" ScaleOut="0.8"
        DurationIn="400" DurationOut="300" EasingIn="SinOut" EasingOut="SinIn"
        HasBackgroundAnimation="True"/>
    </pages:PopupPage.Animation>-->
    <pages:PopupPage.Resources>
        <ResourceDictionary>
            <toolkit:IsStringNullOrEmptyConverter x:Key="IsStringNullConverter" />
            <helper:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </pages:PopupPage.Resources>
    <Border VerticalOptions="Center" StrokeShape="RoundRectangle 10" Margin="20,40">
        <Grid HorizontalOptions="Fill" RowDefinitions="Auto,Auto,Auto" RowSpacing="0"
              ColumnDefinitions="*,*" VerticalOptions="Center" Margin="15,15,15,0"
              ColumnSpacing="0">
            <!--title-->
            <Label x:Name="lbl_title" Style="{StaticResource AlertTitle}" HorizontalOptions="Start"
                   HorizontalTextAlignment="Start" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                   Margin="0,0,0,15" IsVisible="False"/>
            <!--content-->
            <Label x:Name="lbl_desc" IsVisible="False" Margin="0,0,0,15" HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"/>
            <!--custom view-->
            <ContentView x:Name="view_custom" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                     IsVisible="{Binding Source={x:Reference lbl_desc}, Path=IsVisible,
                     Converter={StaticResource InverseBoolConverter}}"/>
            <!--btn : ok-->
            <Grid x:Name="grid_ok" Grid.Row="2" Grid.Column="0" IsVisible="False" HorizontalOptions="Fill"
                  RowDefinitions="Auto" ColumnDefinitions="*">
                <Label x:Name="lbl_ok" Text="Okay" HeightRequest="50" VerticalOptions="Center"
                       VerticalTextAlignment="Center" Style="{StaticResource PopupPrompt}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnOkay_Tapped" NumberOfTapsRequired="1"/>
                </Grid.GestureRecognizers>
            </Grid>
            <!--btn : cancel-->
            <Grid x:Name="grid_cancel" Grid.Row="2" Grid.Column="1" IsVisible="False"
                  HorizontalOptions="Fill" RowDefinitions="Auto" ColumnDefinitions="*">
                <Label x:Name="lbl_cancel" Text="Cancel" HeightRequest="50" VerticalOptions="Center"
                       VerticalTextAlignment="Center" Style="{StaticResource PopupPrompt}"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnCancel_Tapped" NumberOfTapsRequired="1"/>
                </Grid.GestureRecognizers>
            </Grid>
        </Grid>
    </Border>
</pages:PopupPage>
