<?xml version="1.0" encoding="utf-8" ?>
<ViewCell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
          xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
          x:Class="wwrc_maui.Content.Views.Media.Product.ProductCell">

    <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Fill" Spacing="0">
        <Grid HorizontalOptions="Fill" VerticalOptions="Fill" ColumnSpacing="10" Margin="15,10"
              RowDefinitions="Auto" ColumnDefinitions="Auto,*,Auto">
            <!--img : file-->
            <Image Source="{Binding FileImage}" HeightRequest="40" Aspect="AspectFit"
                   HorizontalOptions="Start" VerticalOptions="Center"/>
            <!--file details-->
            <VerticalStackLayout HorizontalOptions="Fill" VerticalOptions="Center" Grid.Column="1"
                                 Spacing="0">
                <!--file title-->
                <Label Text="{Binding Title}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                       LineBreakMode="TailTruncation" MaxLines="1">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="false">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Style" Value="{StaticResource PopupPromptButton}"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="true">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Style" Value="Default"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                <!--file details-->
                <HorizontalStackLayout Spacing="5" HorizontalOptions="Fill">
                    <Label Text="{Binding CreateDate}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                           LineBreakMode="TailTruncation" MaxLines="1">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="false">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Style" Value="{StaticResource PopupPromptButton}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="true">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Style" Value="Default"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                    <Label Text=" | " HorizontalOptions="Start" HorizontalTextAlignment="Start"
                           LineBreakMode="TailTruncation" MaxLines="1"/>
                    <Label Text="{Binding Filesize}" HorizontalOptions="Start" HorizontalTextAlignment="Start"
                           LineBreakMode="TailTruncation" MaxLines="1">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="false">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Style" Value="{StaticResource PopupPromptButton}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsRead}" Value="true">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="Style" Value="Default"/>
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>
                </HorizontalStackLayout>
            </VerticalStackLayout>
            <!--img : icon-->
            <StackLayout VerticalOptions="Center" HorizontalOptions="End" Padding="10,15,0,15"
                         IsVisible="{Binding IsFile}" Spacing="0" Grid.Column="2">
                <Image Source="ic_elipse_info" HeightRequest="30" Aspect="AspectFit" VerticalOptions="Center"
                       HorizontalOptions="End"/>
                <StackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnStatus_Tapped" CommandParameter="{Binding .}"
                                          NumberOfTapsRequired="1" />
                </StackLayout.GestureRecognizers>
            </StackLayout>
        </Grid>
        <BoxView HeightRequest="1" HorizontalOptions="Fill"/>
    </VerticalStackLayout>

</ViewCell>
